# =============================================================================
# 1) Copy & fill
# =============================================================================
# Copy this file to `.env.local` in the repo root. Fill in the blanks below.
# Never commit `.env.local` (it is gitignored).

# =============================================================================
# 2) Supabase — Authentication → URL Configuration (dashboard checklist)
# =============================================================================
# Open: Supabase dashboard → your project → Authentication → URL Configuration
#
# Step A — Redirect URLs (allowlist). Click “Add URL” for each full URL:
#   http://localhost:3000/auth/callback
#   https://YOUR-VERCEL-PROJECT.vercel.app/auth/callback
#   (example: https://benchline-alpha.vercel.app/auth/callback)
# Without these, Google (or any OAuth) will redirect to your app but Supabase
# will reject the handoff and login will fail.
#
# Step B — Site URL (one value; pick what you use most, or use production):
#   • Mostly local dev:  http://localhost:3000
#   • Mostly prod:      https://YOUR-VERCEL-PROJECT.vercel.app
# This is the “home” origin Supabase associates with the project. It does not
# replace the allowlist—you still need every /auth/callback URL in Step A.
#
# After you change Site URL or Redirect URLs, save in the Supabase UI.

# =============================================================================
# 3) Env vars — local (.env.local) vs Vercel (hosting)
# =============================================================================
# LOCAL: only `.env.local`. Set NEXT_PUBLIC_APP_URL to how you open the app:
#   NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# VERCEL: Project → Settings → Environment Variables → Production (and Preview
# if you want). Use the SAME variable names; set production values, e.g.:
#   NEXT_PUBLIC_APP_URL=https://YOUR-VERCEL-PROJECT.vercel.app
#   NEXT_PUBLIC_SUPABASE_URL=…
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=…
#   (plus Stripe / Anthropic if you use them)
# NEXT_PUBLIC_APP_URL must match the real site URL (Stripe Connect return URLs).
# Redeploy after changing env vars on Vercel.

# --- Values for `.env.local` (and mirror on Vercel for prod) ---------------

# Supabase — Project Settings → API (anon / publishable only, not service_role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App origin, no trailing slash (local vs Vercel — see section 3)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Cloud → OAuth Web client → Authorized JavaScript origins must include:
#   http://localhost:3000   and   https://YOUR-VERCEL-PROJECT.vercel.app
# Google’s redirect URI stays: https://<project-ref.>.supabase.co/auth/v1/callback

# Stripe (optional locally; required for real payments / Connect)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Supabase service-role key (server-only). Required for the Stripe webhook, the
# auto-release cron, and audit-log writes (these run without a user session and
# must bypass RLS). NEVER expose this to the client. Supabase dashboard →
# Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# Auto-release cron secret. Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`.
# Generate a random value and set it both here and in Vercel project settings.
CRON_SECRET=

# Platform fee model: `flat` (default, RPC 5.4 safer) or `percentage` (legacy).
FEE_MODE=flat

# AI report structuring (optional)
ANTHROPIC_API_KEY=
