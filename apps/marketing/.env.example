# =============================================================================
# Benchline Marketing Site — Environment Variables
# =============================================================================
# Copy to `.env.local` for local dev. Set the same names in Vercel
# (Project → Settings → Environment Variables) for production.
# The site builds and runs WITHOUT these — the waitlist form falls back to
# logging signups to the server console when Supabase/Resend are unset.

# Public site origin, no trailing slash (used for canonical/OG/sitemap URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App subdomain for "Sign in" links (the main Benchline app)
NEXT_PUBLIC_APP_URL=https://app.benchline.com

# --- Supabase (waitlist table) ---------------------------------------------
# RECOMMENDED: reuse the SAME Supabase project as the main app, with a new
# `waitlist` table (see README → "Supabase setup"). The marketing site only
# needs the URL + a key able to INSERT into `waitlist`.
# Use the SERVICE ROLE key here (server-only — never exposed to the browser)
# so the insert works regardless of RLS. Keep it secret.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (waitlist confirmation email) ----------------------------------
RESEND_API_KEY=
# Verified sender address for confirmation emails
RESEND_FROM_EMAIL=Benchline <hello@benchline.com>
